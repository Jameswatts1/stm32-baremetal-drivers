#include "stm32c031xx.h"
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <math.h>
void PWM_INIT(void);
void PWM_INIT(void) {

GPIOA->AFR[0] &= ~(15 << 24);//CLEARS BIT PA6 UNDER ALTERNATE FUNCTION
GPIOA->AFR[0] |= (1<<24);// SETS BIT PA6 TO AF1
GPIOA->OSPEEDR &= ~(3 << 12);//CLEARS BIT 12 AND 13 PA6
GPIOA->OSPEEDR |= (3<<12);//SETS PA6 TO ULTRA SPEED
TIM3->CCMR1 &= ~(7 << 4);//CLEARS BIT 4,5 AND 6(OC1M)
TIM3->CCMR1 |= (6<<4);//SETS TIM3 TO PWM MODE
TIM3->CCMR1 &= ~(1 << 3);//CLEARS 3 (OC1PE)
TIM3->CCMR1 |= (1<<3);//SETS BIT 3 TO 1 THIS ENABLES PELOAD
TIM3->CCER &= ~(1 << 0);//CLEARS BIT 0 (CC1E)
TIM3->CCER |= (1<<0);//SET CC1E TO 1 THIS THE MASTER SWITCH THAT ALLOWS YOUR
//DATA TO REACH THE PIN
TIM3->PSC = 288;//SETS THE FREQUENCY TO 166.7KHZ
TIM3->ARR = 4095;//SETS THE FULL CYCLE TO 4095
TIM3->CCR1 = 0;//THE PWM IS SET TO BE HIGH AT 0% BY DEFAULT
TIM3->CR1 &= (0<<2);//CLEARS CONTROL REGISTER
TIM3->CR1 |= (1<<0);//STARTS TIMER (CEN) FOR CHANNEL 1
}
int main() {
RCC->IOPENR |= (1<<0);//ENABLE CLOCK FOR IO
RCC->APBENR1 |= (1<<1);//ENABLE CLOCK FOR TIM3
GPIOA->MODER &= ~(3 << 12);//CLEAR BIT 13 & 12 (PA6)
GPIOA->MODER |= (1<<13);//SET PA6 MODE TO ALTERNATE FUNCTION
RCC->APBENR2 |= (1<<20);//ENABLE CLOCK FOR ADC
GPIOA->MODER &= ~(3 << 10);//CLEAR BITS 11 AND 10 (PA5)
GPIOA->MODER |= (3<<10);//SET PA5 TO ADC FUNCTION

//ADC->CHSELR &= ~(1 << 5);
ADC1->CHSELR |= (1<<5);//SET ADC1 TO CHANNEL 5 WHERE PA5 IS CONNECTED
ADC1->CR = (1<<31);//START CALIBRATION FOR ADC (ADCAL)
while(ADC1->CR & (1<<31));// WAIT FOR CALIBRATION TO BE COMPLETE 
//ADCAL WILL AUTOMATICALLY TURN BACK TO ZERO WHEN CALIBRATION IS COMPLETE
ADC1->CR |= (1<<0);//ENBLE ADC1 (ADEN), MUST ONLY BE DONE WHEN CALIBRATION IS 
//COMPLETE
while(!(ADC1->ISR & (1<<0)));//WAIT FOR ADC TO BE FULLY ENABLED(ADRDY)
PWM_INIT();//CALLS THE PWM FUNCTION
  while(1) {
ADC1->CR |= (1<<2);//STARTS ADC(ADSTART)
while(!(ADC1->ISR & (1<<2)));//WAITS FOR ADC TO GET VALUE(EOC)
TIM3->CCR1 = ADC1->DR;//STORES ADCVALUE IN CAPTURE/COMPARE REGISTER
}
  return 0;
}
